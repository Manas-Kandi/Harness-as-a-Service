# DEFAULT_MONTHLY_SPEND_CAP=50

# Optional: override the default auto-approve threshold in dollars (default: 0.15)
# DEFAULT_AUTO_APPROVE_THRESHOLD=0.15

# Future LLM integration
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
